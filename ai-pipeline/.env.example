# Manga Reader AI Pipeline — Environment Configuration
# Copy to .env and fill in your keys.

# Server
MANGA_AI_SERVER_HOST=127.0.0.1
MANGA_AI_SERVER_PORT=8500

# Gemini (Vision + default LLM)
MANGA_AI_GEMINI_API_KEY=your_gemini_api_key_here
MANGA_AI_GEMINI_MODEL=gemini-2.0-flash
MANGA_AI_GEMINI_DETAIL=low

# LLM (overrides Gemini LLM settings if different)
MANGA_AI_LLM_PROVIDER=gemini
MANGA_AI_LLM_MODEL=gemini-2.0-flash
MANGA_AI_LLM_API_KEY=
MANGA_AI_LLM_MAX_TOKENS=4096

# TTS
MANGA_AI_TTS_PROVIDER=kokoro
MANGA_AI_TTS_VOICE=af_heart
MANGA_AI_TTS_SPEED=1.0
MANGA_AI_ELEVENLABS_API_KEY=
MANGA_AI_ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# OCR
MANGA_AI_OCR_LANGUAGES=["ja","en"]
MANGA_AI_OCR_GPU=true

# Paths
MANGA_AI_OUTPUT_DIR=output
MANGA_AI_TMP_DIR=tmp
