<Page
    x:Class="MangaReader.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaReader.ViewModels"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" MaxWidth="700" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource PageHeaderStyle}" />

            <!-- Connection Settings -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Connection" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AppForegroundBrush}" />
                    <Separator Background="{StaticResource DividerBrush}" />

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Status:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Width="100" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToConnectionColor}}" />
                            <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectionText}}"
                                       Foreground="{StaticResource AppForegroundBrush}" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Engine:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Width="100" />
                        <TextBlock Grid.Column="1" Text="ws://127.0.0.1:9721"
                                   Foreground="{StaticResource AppForegroundBrush}" />
                    </Grid>

                    <Button Content="{Binding IsConnected, Converter={StaticResource BoolToConnectAction}}"
                            Command="{Binding ConnectCommand}"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            CornerRadius="6"
                            Padding="16,8"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Reading Preferences -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reading" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AppForegroundBrush}" />
                    <Separator Background="{StaticResource DividerBrush}" />

                    <Grid ColumnDefinitions="Auto,Auto">
                        <TextBlock Grid.Column="0" Text="Double page mode:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0" />
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{Binding DoublePageMode, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,Auto">
                        <TextBlock Grid.Column="0" Text="Fit to width:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0" />
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{Binding FitToWidth, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cache Settings -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Cache" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AppForegroundBrush}" />
                    <Separator Background="{StaticResource DividerBrush}" />

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="Current cache size:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Width="140" />
                        <TextBlock Grid.Column="1"
                                   Foreground="{StaticResource AppForegroundBrush}">
                            <Run Text="{Binding CacheSizeMb, Mode=OneWay}" />
                            <Run Text=" MB" />
                        </TextBlock>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Clear Cache"
                                Command="{Binding ClearCacheCommand}"
                                Background="#FF4444" Foreground="White"
                                CornerRadius="6"
                                Padding="16,8" />
                        <Button Content="Refresh"
                                Command="{Binding RefreshCacheSizeCommand}"
                                Background="{StaticResource SurfaceBrush}"
                                Foreground="{StaticResource AppForegroundBrush}"
                                CornerRadius="6"
                                Padding="16,8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="About" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AppForegroundBrush}" />
                    <Separator Background="{StaticResource DividerBrush}" />

                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Manga Reader v" />
                        <Run Text="2.0.0" />
                    </TextBlock>
                    <TextBlock Text="WinUI 3 + SkiaSharp GPU-accelerated manga reader frontend."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="Powered by the Rust manga-panel-extractor engine."
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
