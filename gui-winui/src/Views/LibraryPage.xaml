<Page
    x:Class="MangaReader.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaReader.ViewModels"
    xmlns:models="using:MangaReader.Models"
    xmlns:controls="using:MangaReader.Controls"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Library" Style="{StaticResource PageHeaderStyle}" />

        <!-- Search + toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <TextBox x:Name="SearchBox"
                     Width="320"
                     Style="{StaticResource SearchBoxStyle}"
                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button x:Name="RefreshBtn"
                    Content="&#x21BB; Refresh"
                    Command="{Binding LoadLibraryCommand}"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource AppForegroundBrush}"
                    CornerRadius="6"
                    Padding="16,8" />
            <Button x:Name="ConnectBtn"
                    Content="{Binding IsConnected, Converter={StaticResource BoolToConnectText}}"
                    Command="{Binding ConnectCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    CornerRadius="6"
                    Padding="16,8" />
        </StackPanel>

        <!-- Manga grid (adaptive wrap panel) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{Binding MangaCollection}"
                           HorizontalLayout="Left"
                           AnimationMode="ShowAll">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinColumnSpacing="16"
                        MinRowSpacing="16"
                        MinItemWidth="180"
                        MinItemHeight="260" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:Manga">
                        <Border CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                                PointerEntered="OnCoverPointerEntered"
                                PointerExited="OnCoverPointerExited"
                                PointerPressed="OnCoverPointerPressed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Cover canvas placeholder -->
                                <controls:MangaCover
                                    x:Name="CoverControl"
                                    Grid.Row="0"
                                    Manga="{x:Bind}"
                                    CornerRadius="8"
                                    ShowBadge="True" />

                                <!-- Title and metadata strip -->
                                <StackPanel Grid.Row="1" Margin="8,6">
                                    <TextBlock Text="{x:Bind Title}"
                                               Foreground="{StaticResource AppForegroundBrush}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="{x:Bind Author}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding MangaCollection.Count, Converter={StaticResource EmptyToVisibility}}">
            <TextBlock Text="&#x1F4DA;" FontSize="64" HorizontalAlignment="Center" />
            <TextBlock Text="No manga in your library" FontSize="18"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="Connect to the engine and refresh to load your collection."
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</Page>
