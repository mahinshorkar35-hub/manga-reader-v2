<Page
    x:Class="MangaReader.Views.ReaderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaReader.ViewModels"
    xmlns:controls="using:MangaReader.Controls"
    mc:Ignorable="d"
    Background="#0D0D0D"
    KeyDown="OnPageKeyDown">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar (auto-hides after inactivity) -->
        <Border x:Name="TopBar" Grid.Row="0"
                Background="#CC1A1A1A" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0"
                        Content="&#x2190; Back to Library"
                        Command="{Binding NavigateToCommand}" CommandParameter="Library"
                        Background="Transparent"
                        Foreground="{StaticResource AppForegroundBrush}"
                        FontSize="14"
                        Padding="8,4" />

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ReaderTitle}"
                           Foreground="{StaticResource AppForegroundBrush}"
                           FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Page counter -->
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14">
                    <Run Text="{Binding CurrentPageIndex, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding CurrentPages.Count, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- SkiaSharp GPU page renderer -->
        <controls:PageView
            x:Name="PageRenderer"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Tapped="OnPageTapped"
            DoubleTapped="OnPageDoubleTapped"
            PointerWheelChanged="OnPointerWheelChanged" />

        <!-- Navigation overlay (left/right tap zones) -->
        <Grid Grid.Row="1" IsHitTestVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Fill="Transparent" IsHitTestVisible="False" />
            <Rectangle Grid.Column="1" Fill="Transparent" IsHitTestVisible="False" />
        </Grid>

        <!-- Bottom controls bar -->
        <Border x:Name="BottomBar" Grid.Row="2"
                Background="#CC1A1A1A" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Progress slider -->
                <Slider Grid.Column="0"
                        Minimum="0"
                        Maximum="{Binding CurrentPages.Count, FallbackValue=1}"
                        Value="{Binding CurrentPageIndex, Mode=TwoWay}"
                        Width="400"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AccentBrush}" />

                <!-- Zoom controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="&#x2013;"
                            Command="{Binding PreviousPageCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource AppForegroundBrush}"
                            Width="40" Height="40"
                            CornerRadius="20" FontSize="20" />
                    <Button Content="+"
                            Command="{Binding NextPageCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource AppForegroundBrush}"
                            Width="40" Height="40"
                            CornerRadius="20" FontSize="20" />
                    <Button Content="&#x26F6;"
                            Command="{Binding ToggleFullScreenCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            Foreground="{StaticResource AppForegroundBrush}"
                            Width="40" Height="40"
                            CornerRadius="20" FontSize="18" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
