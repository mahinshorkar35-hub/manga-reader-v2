<Application
    x:Class="MangaReader.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App-wide color palette -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF6B35" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF8C5A" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D2D" />
            <SolidColorBrush x:Key="SurfaceLightBrush" Color="#3D3D3D" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAAAA" />
            <SolidColorBrush x:Key="DividerBrush" Color="#404040" />

            <!-- Navigation styles -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Height" Value="48" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="24,0" />
            </Style>

            <!-- Page header style -->
            <Style x:Key="PageHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <!-- Card / surface style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <!-- Search box style -->
            <Style x:Key="SearchBoxStyle" TargetType="TextBox">
                <Setter Property="PlaceholderText" Value="Search manga..." />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Height" Value="40" />
                <Setter Property="FontSize" Value="16" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
