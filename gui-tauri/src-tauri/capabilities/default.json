{
  "identifier": "default",
  "description": "Default permissions for Manga Reader v2",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "shell:default",
    "shell:allow-open",
    "process:default",
    "process:allow-exit"
  ]
}
